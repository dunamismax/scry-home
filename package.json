{
  "name": "scry-home",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm --recursive --filter './apps/*' --filter './packages/*' run build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "dev": "pnpm --filter @scry-home/web dev",
    "format": "pnpm --recursive --filter './apps/*' --filter './packages/*' run format",
    "lint": "pnpm --recursive --filter './apps/*' --filter './packages/*' run lint",
    "test": "pnpm --recursive --filter './apps/*' --filter './packages/*' run test",
    "typecheck": "pnpm --recursive --filter './apps/*' --filter './packages/*' run typecheck",
    "db:generate": "pnpm --filter @scry-home/db generate",
    "db:migrate": "pnpm --filter @scry-home/db migrate",
    "cli": "pnpm --filter @scry-home/cli cli"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
