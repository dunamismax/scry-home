{
  "name": "scry-home",
  "description": "Canonical Scry persona and prompt repo with optional Bun-based helper tooling.",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "bun run --workspaces --if-present build",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build",
    "dev": "bun run --filter @scry-home/web dev",
    "format": "bun run --workspaces --if-present format",
    "lint": "bun run --workspaces --if-present lint",
    "test": "bun run --workspaces --if-present test",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "db:generate": "bun run --filter @scry-home/db generate",
    "db:migrate": "bun run --filter @scry-home/db migrate",
    "cli": "bun run ./packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
