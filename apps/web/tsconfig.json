{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "paths": {
      "#/*": ["./src/*"],
      "@/*": ["./src/*"]
    },
    "noUncheckedSideEffectImports": true
  }
}
