{
  "name": "@scry-home/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "bunx --bun vite build",
    "dev": "bunx --bun vite dev --port 3000",
    "format": "biome format --write .",
    "lint": "biome check .",
    "preview": "bunx --bun vite preview",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "bunx --bun tsc -p tsconfig.json"
  },
  "dependencies": {
    "@scry-home/core": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.9.13",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/react-router-ssr-query": "^1.166.7",
    "@tanstack/react-start": "^1.166.8",
    "@tanstack/router-plugin": "^1.166.7",
    "lucide-react": "^0.577.0",
    "nitro": "3.0.260311-beta",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.5.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
